// nextflow.config

params {
    genome               = 'hg38'
    cellranger_arc_ref   = null   // path to Cell Ranger ARC reference
    outdir               = 'results'
    input                = null
}

profiles {
    local       { process.executor='local'; process.cpus=8;  process.memory='64 GB' }
    docker      { docker.enabled=true; docker.runOptions='-u $(id -u):$(id -g)' }
    singularity { singularity.enabled=true; singularity.autoMounts=true }
    slurm       { process.executor='slurm'; process.queue='high_mem';
                  process.time='48h'; process.cpus=32; process.memory='128 GB' }
}

process {
    withName: 'CELLRANGER_ARC' {
        container = '10xgenomics/cellranger-arc:2.0.2'
        cpus      = 32
        memory    = '128 GB'
        time      = '48h'
    }
    withName: 'FASTQC'  { container='biocontainers/fastqc:0.11.9' }
    withName: 'MULTIQC' { container='biocontainers/multiqc:1.13' }
}

report   { enabled=true; file="${params.outdir}/pipeline_report.html" }
timeline { enabled=true; file="${params.outdir}/timeline.html" }
